
BSSID=$(awk -F',' -v essid="$ESSID" '
NF > 13 {
    gsub(/^ +| +$/, "", $1)
    gsub(/^ +| +$/, "", $14)

    if ($14 == essid) {
        print $1
        exit
    }
}' scan-01.csv)

